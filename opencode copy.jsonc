{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "rolebase": {
      "type": "local",
      "command": ["npx", "tsx", "packages/mcp/src/index.ts"],
      "environment": {
        "ROLEBASE_API_URL": "{env:ROLEBASE_API_URL}",
        "ROLEBASE_API_KEY": "{env:ROLEBASE_API_KEY}"
      },
      "enabled": true,
      "timeout": 10000
    }
  },
  "experimental": {
    "mcp_timeout": 240000
  }
}
