---
interface Props {
  class?: string
  align?: 'center' | 'start'
  // On mobile, stack the right slot above the left one (columns are still
  // left|right on desktop). Use it to keep an illustration on top, or a video
  // below its text, regardless of slot order.
  mobileReverse?: boolean
}

const { class: className, align = 'center', mobileReverse = false } = Astro.props

const slotClass = "w-full flex-1 [&_h2.md]:text-3xl [&_h2.md]:md:text-4xl [&_h2.md]:font-bold [&_h2.md]:mt-0 [&_h2.md]:mb-0 [&>p.md]:mb-0 [&>p.md]:mt-4 [&_h2.md+p.md]:mt-6 [&>p.md]:text-lg [&_img]:rounded-full [&_img]:w-full [&_img]:max-w-md [&_img]:mx-auto [&_img]:aspect-square [&_img]:object-cover"
---

<section class:list={[
  "mt-24 flex md:flex-row gap-12",
  mobileReverse ? 'flex-col-reverse' : 'flex-col',
  align === 'start' ? 'md:items-start' : 'items-center',
  className,
]}>
  <div class={slotClass}>
    <slot name="left" />
  </div>
  <div class={slotClass}>
    <slot name="right" />
  </div>
</section>
