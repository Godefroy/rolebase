---
import Button from './Button.astro'

interface Props {
  title: string
  primaryLabel: string
  primaryHref: string
  secondaryLabel?: string
  secondaryHref?: string
}

const {
  title,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
} = Astro.props

const riveUrl = 'https://rive.app/s/kBdu3ZNaY0_sU2RqJmUTUQ/embed'
---

<div class="bg-yellow-100 rounded-2xl flex flex-col md:flex-row items-center gap-8 max-w-4xl mx-auto p-8 md:p-12 ">
  {riveUrl && (
    <div class="flex-shrink-0">
      <iframe style="border: none" width="250" height="200" src={riveUrl} allowfullscreen></iframe>
    </div>
  )}
  <div>
    <h2 class="text-xl md:text-2xl font-bold">{title}</h2>
    <p class="mt-4 text-text-secondary"><slot /></p>
    <div class="flex flex-wrap gap-4 mt-6">
      <Button href={primaryHref} variant="outline" label={primaryLabel} />
      {secondaryLabel && secondaryHref && (
        <Button href={secondaryHref} variant="orange" label={secondaryLabel} />
      )}
    </div>
  </div>
</div>
