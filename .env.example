# DataForSEO — SEO analysis (ranked keywords, keyword research, competitors, backlinks, SERP, on-page audit)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Search Console — real search performance data (impressions, clicks, CTR, positions)
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
GSC_SITE_URL=sc-domain:rolebase.io

# Umami Analytics — self-hosted analytics (pageviews, engagement, bounce rate)
UMAMI_API_KEY=
UMAMI_BASE_URL=

# Google AI — Nano Banana Pro image generation for blog thumbnails
GOOGLE_AI_API_KEY=

# Sentry
# Auth token with project:read + project:releases (+ org:read) scopes.
# Create at https://sentry.lonestone.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
# Sourcemap upload (webapp build): set these in the Netlify build env so
# @sentry/vite-plugin uploads sourcemaps. Without them the plugin is skipped.
SENTRY_URL=https://sentry.lonestone.io
SENTRY_ORG=lonestone
SENTRY_PROJECT=rolebase-webapp
